# Claude Code workspace config: contains absolute $HOME paths in
# launch.json + start-dev.sh and a per-user permission allowlist in
# settings.local.json. Ignored wholesale to keep the username/local paths
# out of any public-repo push.
.claude/

# Working knowledge base — not part of the deployed bundle.
# Contains the upstream course corpus (third-party videos/PDFs/transcripts
# whose redistribution terms aren't clear), the research source papers,
# planning offload files (todo.md, process-journal.md, ux-polish-audit.md),
# and internal content drafts. All of it is local-only; nothing here ships
# in dist/ or affects what users see.
course-info/

# Cognitive offload files — local-only project management and AI context.
# Not part of the codebase or deployed bundle.
CLAUDE.md
MEMORY.md
ARCHIVE.md
TODO.md
TODOARCHIVE.md

# Claude Code task prompts (local working instruction docs). The
# needs-analysis-content/ subfolder below is intentionally NOT ignored —
# its markdown is imported at build time by the needs-analysis pages.
claude-code/*.md
